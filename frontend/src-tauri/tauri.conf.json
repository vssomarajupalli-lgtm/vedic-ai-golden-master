{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Samartha Vedic AI",
  "version": "1.0.0",
  "identifier": "com.samartha.vedic.ai",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "set TAURI_BUILD=true && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Samartha Vedic AI",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper"
      }
    }
  },
  "plugins": {
    "log": {
      "level": "info"
    },
    "process": {
      "sidecar": [
        {
          "name": "vedic-ai-backend",
          "path": "sidecar/vedic-ai-backend.exe",
          "args": [],
          "env": {
            "PYTHONUNBUFFERED": "1"
          }
        }
      ]
    }
  }
}